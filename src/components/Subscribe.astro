---
import { SITE } from "../lib/site";
---

<div class="frame">
  <span class="frame-title">subscribe</span>
  <div class="subscribe-row">
    <a href="/rss.xml">RSS</a>
    <a href={SITE.linkedin}>LinkedIn</a>
    <form action={SITE.newsletterAction} method="post" target="_blank">
      <label for="nl-email">a deep dive every month or two:</label>
      <input
        id="nl-email"
        type="email"
        name="email"
        required
        placeholder="you@example.com"
      />
      <button type="submit">follow</button>
    </form>
  </div>
</div>
