---
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import Base from "../../layouts/Base.astro";
import BacktraceToc from "../../components/BacktraceToc.astro";
import AuthorCard from "../../components/AuthorCard.astro";
import Subscribe from "../../components/Subscribe.astro";
import { SITE, fmtDate, readingTime, seriesSlug } from "../../lib/site";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { title, description, date, updated, series, discussion } = post.data;
const { Content, headings } = await render(post);

// series navigation
const seriesPosts = series
  ? (await getCollection("blog", ({ data }) => !data.draft))
      .filter((p) => p.data.series?.name === series.name)
      .sort((a, b) => (a.data.series?.part ?? 0) - (b.data.series?.part ?? 0))
  : [];
const prev = series
  ? seriesPosts.find((p) => p.data.series?.part === series.part - 1)
  : undefined;
const next = series
  ? seriesPosts.find((p) => p.data.series?.part === series.part + 1)
  : undefined;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: title,
    description,
    datePublished: date.toISOString(),
    ...(updated ? { dateModified: updated.toISOString() } : {}),
    url: new URL(`/blog/${post.id}/`, Astro.site).href,
    image: new URL(`/og/blog/${post.id}.png`, Astro.site).href,
    author: {
      "@type": "Person",
      name: SITE.author,
      url: SITE.url,
      sameAs: [SITE.linkedin, SITE.github],
    },
  },
];
---

<Base
  title={`${title} · ${SITE.title}`}
  description={description}
  canonical={`/blog/${post.id}/`}
  ogType="article"
  ogImage={`/og/blog/${post.id}.png`}
  jsonLd={jsonLd}
  current="blog"
>
  <main class="shell">
    <div class="post-grid">
      <BacktraceToc headings={headings} />

      <article class="article">
        <header class="post-header">
          <h1>{title}</h1>
          <p class="dek">{description}</p>
          <p class="meta">
            <b>{SITE.author}</b>
            <span>published {fmtDate(date)}</span>
            <span>{readingTime(post.body ?? "")}</span>
            {
              series && (
                <span class="chip-pill">
                  {series.name} · Part {series.part}
                </span>
              )
            }
          </p>
        </header>

        <div class="article-body">
          <Content />
        </div>

        {
          (prev || next) && (
            <div class="frame series-nav">
              <span class="frame-title">series — {series!.name}</span>
              <span class="frame-tag">
                part {series!.part} of {seriesPosts.length}
              </span>
              <div class="series-nav-links">
                <a href={`/series/${seriesSlug(series!.name)}/`}>all parts</a>
                {prev && (
                  <a href={`/blog/${prev.id}/`}>
                    ← Part {prev.data.series!.part}: {prev.data.title}
                  </a>
                )}
                {next && (
                  <a href={`/blog/${next.id}/`}>
                    Part {next.data.series!.part}: {next.data.title} →
                  </a>
                )}
                </div>
            </div>
          )
        }

        {
          discussion && Object.keys(discussion).length > 0 && (
            <p class="discussion">
              discussed on:{" "}
              {Object.entries(discussion).map(([venue, url], i) => (
                <>
                  {i > 0 && " · "}
                  <a href={url}>{venue}</a>
                </>
              ))}
            </p>
          )
        }

        <AuthorCard />
        <div style="margin-top:1.5rem"><Subscribe /></div>
      </article>
    </div>
  </main>
</Base>

<script>
  import { mountLoaderStepper } from "../../scripts/loader-stepper";
  document
    .querySelectorAll<HTMLElement>("[data-loader-stepper]")
    .forEach(mountLoaderStepper);
</script>
