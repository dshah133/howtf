---
import Base from "../layouts/Base.astro";
import { SITE } from "../lib/site";
---

<Base
  title={`colophon · ${SITE.title}`}
  description="How howtf.io is built."
  canonical="/colophon/"
>
  <main class="shell">
    <div class="home-center">
      <div class="frame">
        <span class="frame-title">cat colophon</span>
        <div>
          <p>
            Built with <a href="https://astro.build">Astro</a> and
            <a href="https://expressive-code.com">Expressive Code</a>. Display
            type is <a href="https://departuremono.com">Departure Mono</a>
            (OFL), body is Alegreya Sans, code is JetBrains Mono. Design
            direction: <em>Core Dump</em> — a TUI rendered to the web, in CRT
            amber. Hosted on GitHub Pages; analytics by
            <a href="https://plausible.io">Plausible</a> (no cookies).
          </p>
          <p style="margin-top:1rem">
            Diagrams use a fixed entity color code across every post: file
            sections, memory segments, the loader, and the kernel each keep one
            hue, everywhere.
          </p>
        </div>
      </div>
    </div>
  </main>
</Base>
